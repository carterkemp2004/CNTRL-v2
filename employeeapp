    const weeklySchedule = [[1, 2], [3, 9], [4, 5, 6], [7, 10], [11, 8], [], []];

    const agendaHTML = `
        <div class="schedule-container"><div class="timeline-grid">
            <div><div class="time-label">8A</div><div class="time-label">9A</div><div class="time-label">10A</div><div class="time-label">11A</div><div class="time-label">12P</div><div class="time-label">1P</div><div class="time-label">2P</div><div class="time-label">3P</div><div class="time-label">4P</div></div>
            <div class="day-column"><div class="slot"><div class="job-block site-1" style="height:30px;">SITE 1</div></div><div class="slot"></div><div class="slot"></div><div class="slot"></div><div class="slot"></div><div class="slot"></div><div class="slot"></div><div class="slot"></div><div class="slot"><div class="job-block lunch-block" style="height:10px;">LUNCH</div></div><div class="slot"></div><div class="slot"><div class="job-block site-2" style="height:20px;">SITE 2</div></div></div>
            <div class="day-column"><div class="slot"></div><div class="slot"></div><div class="slot"><div class="job-block site-3" style="height:40px;">SITE 3</div></div><div class="slot"></div><div class="slot"></div><div class="slot"></div><div class="slot"></div><div class="slot"></div><div class="slot"><div class="job-block lunch-block" style="height:10px;">LUNCH</div></div><div class="slot"></div><div class="slot"><div class="job-block site-9" style="height:20px;">SITE 9</div></div></div>
            <div class="day-column"><div class="slot"><div class="job-block site-4" style="height:20px;">SITE 4</div></div><div class="slot"></div><div class="slot"></div><div class="slot"><div class="job-block site-5" style="height:20px;">SITE 5</div></div><div class="slot"></div><div class="slot"></div><div class="slot"></div><div class="slot"></div><div class="slot"><div class="job-block lunch-block" style="height:10px;">LUNCH</div></div><div class="slot"></div><div class="slot"><div class="job-block site-6" style="height:30px;">SITE 6</div></div></div>
            <div class="day-column"><div class="slot"></div><div class="slot"></div><div class="slot"></div><div class="slot"></div><div class="slot"><div class="job-block site-7" style="height:20px;">SITE 7</div></div><div class="slot"></div><div class="slot"></div><div class="slot"></div><div class="slot"><div class="job-block lunch-block" style="height:10px;">LUNCH</div></div><div class="slot"></div><div class="slot"><div class="job-block site-10" style="height:20px;">SITE 10</div></div></div>
            <div class="day-column"><div class="slot"><div class="job-block site-11" style="height:20px;">SITE 11</div></div><div class="slot"></div><div class="slot"></div><div class="slot"></div><div class="slot"></div><div class="slot"></div><div class="slot"><div class="job-block site-8" style="height:20px;">SITE 8</div></div><div class="slot"></div><div class="slot"><div class="job-block lunch-block" style="height:10px;">LUNCH</div></div></div>
            <div class="day-column"></div><div class="day-column"></div>
        </div></div><div style="display:flex; justify-content:space-between; margin-top:6px; font-size:7px; font-weight:800; color:#b2bec3; padding-left:33px;"><span>M</span><span>T</span><span>W</span><span>T</span><span>F</span><span>S</span><span>S</span></div>`;

    function showView(viewId, navId) {
        ['dashboard-view', 'time-view', 'jobsite-view', 'job-detail-view', 'pay-view'].forEach(v => document.getElementById(v).style.display = 'none');
        document.getElementById(viewId).style.display = 'block';
        if(navId) { document.querySelectorAll('.nav-btn').forEach(btn => btn.classList.remove('active')); document.getElementById(navId).classList.add('active'); }
        updateUI();
    }

    function openJobDetail(id) {
        const job = jobsList.find(j => j.id === id);
        const mount = document.getElementById('detail-card-mount');
        mount.innerHTML = `
            <div class="card"><div class="row"><h2 style="color: var(--${job.color}); font-size: 14px;">${job.name}</h2><button class="btn-map" onclick="openMap('${job.addr}')">MAP IT</button></div><p style="font-size:11px; color:#7f8c8d; margin-top:5px;">${job.addr}</p></div>
            <div class="card"><h2>Action Checklist</h2>${job.tasks.map(t => `<div class="checklist-item"><input type="checkbox"> <span>${t}</span></div>`).join('')}</div>
            <div class="card"><h2>Special Notes</h2><div class="note-box">${job.note}</div></div>`;
        showView('job-detail-view');
    }

    function updateTodayJobs() {
        let rawDay = new Date().getDay();
        const todayIdx = rawDay === 0 ? 6 : rawDay - 1;
        const jobIds = weeklySchedule[todayIdx];
        const container = document.getElementById('todays-jobs-container');
        if (jobIds.length === 0) { container.innerHTML = `<p style="font-size: 11px; color: #7f8c8d; text-align: center; margin: 10px 0;">No jobs scheduled for today.</p>`; return; }
        container.innerHTML = jobIds.map(id => {
            const job = jobsList.find(j => j.id === id);
            return `<div class="job-entry"><div class="row"><div><span class="job-tag" style="background: var(--${job.color})">JOBSITE ${job.id}</span><div style="font-weight: 800; font-size: 13px; color: #2d3436;">${job.name}</div><div style="color: #7f8c8d; font-size: 10px;">${job.addr}</div></div><button class="btn-map" onclick="openMap('${job.addr}')">MAP IT</button></div></div>`;
        }).join('');
    }

    function updateUI() {
        let rawDay = new Date().getDay();
        const todayIdx = rawDay === 0 ? 6 : rawDay - 1;
        const currentDayMs = weekData[todayIdx] + elapsedTime;
        let hh = Math.floor(elapsedTime / 3600000), mm = Math.floor((elapsedTime % 3600000) / 60000), ss = Math.floor((elapsedTime % 60000) / 1000);
        document.getElementById('timerDisplay').innerText = `${hh}H ${mm.toString().padStart(2,'0')}M ${ss.toString().padStart(2,'0')}S`;
        document.getElementById('dashCenterHrs').innerText = formatHM(currentDayMs);
        if(document.getElementById('timeViewDayHrs')) {
            document.getElementById('timeViewDayHrs').innerText = formatHM(currentDayMs);
            document.getElementById('dailyMirrorDisplay').innerText = formatHM(currentDayMs);
            document.getElementById('dailyMirrorCircle').style.strokeDashoffset = circ - (Math.min((currentDayMs/3600000) / 8, 1) * circ);
        }
        document.getElementById('progressCircle').style.strokeDashoffset = circ - (Math.min((currentDayMs/3600000) / 8, 1) * circ);
        let weeklyTotalMs = weekData.reduce((a, b) => a + b, 0) + elapsedTime;
        let weeklyHrs = weeklyTotalMs / 3600000;
        if(document.getElementById('weeklyGoalIconText')) {
            document.querySelectorAll('#weeklyGoalIconText').forEach(el => el.innerText = formatHM(weeklyTotalMs));
            document.querySelectorAll('#weeklyTotalText').forEach(el => el.innerText = formatHM(weeklyTotalMs));
            document.getElementById('weeklyGoalCircle').style.strokeDashoffset = circ - (Math.min(weeklyHrs / 40, 1) * circ);
        }
        weekData.forEach((ms, idx) => {
            let total = (idx === todayIdx) ? (ms + elapsedTime) / 3600000 : ms / 3600000;
            let bar = document.getElementById(`bar-${idx}`), lab = document.getElementById(`lab-${idx}`);
            if(bar && lab) { lab.innerText = total.toFixed(1); bar.style.height = Math.min((total / 10) * 100, 100) + "%"; bar.style.background = total > 8 ? "var(--emergency-red)" : "var(--primary-blue)"; }
        });
        const pastWeeks = [weeklyHrs, 38.5, 42.2, 35.0, 39.8]; 
        let points = [];
        pastWeeks.forEach((hrs, idx) => {
            const wbar = document.getElementById(`w-bar-${idx}`), wlab = document.getElementById(`w-lab-${idx}`), wdate = document.getElementById(`w-date-${idx}`);
            if(wbar && wlab) { wlab.innerText = hrs.toFixed(1); wbar.style.height = Math.min((hrs / 50) * 100, 100) + "%"; if(idx !== 0 && wdate) wdate.innerText = getMondayLabel(idx); }
            const weeklyPay = calculatePayFromHrs(hrs), y = 120 - (Math.min(weeklyPay / 1100, 1) * 90), x = 390 - (idx * 95);
            points.push(`${x},${y}`);
            const pdot = document.getElementById(`p-dot-${idx}`), pval = document.getElementById(`p-val-${idx}`), pdate = document.getElementById(`p-date-${idx}`);
            if(pdot) pdot.setAttribute("cy", y); if(pval) { pval.setAttribute("y", y - 12); pval.textContent = `$${Math.round(weeklyPay)}`; } if(pdate && idx !== 0) pdate.innerText = getMondayLabel(idx);
        });
        if(document.getElementById('payLine')) document.getElementById('payLine').setAttribute("points", points.reverse().join(" "));
        const totalPay = calculatePayFromHrs(weeklyHrs);
        if(document.getElementById('estimatedEarnings')) {
            document.getElementById('estimatedEarnings').innerText = `$${totalPay.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
            document.getElementById('breakdownReg').innerText = `${Math.min(weeklyHrs, 40).toFixed(1)} hrs`;
            document.getElementById('breakdownOT').innerText = `${Math.max(0, weeklyHrs - 40).toFixed(1)} hrs`;
        }
        updateTodayJobs();
    }

    document.getElementById('mainToggleBtn').onclick = function() {
        isClockedIn = !isClockedIn;
        if (isClockedIn) {
            this.innerText = "CLOCK OUT"; this.style.background = "linear-gradient(135deg, #ff7675, #d63031)";
            document.getElementById('statusLabel').innerText = "CLOCKED IN";
            startTime = Date.now(); timerInterval = setInterval(() => { elapsedTime = Date.now() - startTime; updateUI(); }, 1000);
        } else {
            this.innerText = "CLOCK IN"; this.style.background = "linear-gradient(135deg, #2ecc71, #27ae60)";
            document.getElementById('statusLabel').innerText = "CLOCKED OUT";
            clearInterval(timerInterval); weekData[new Date().getDay() === 0 ? 6 : new Date().getDay()-1] += elapsedTime;
            elapsedTime = 0; localStorage.setItem('cntrl_week_times_7day', JSON.stringify(weekData)); updateUI();
        }
    };

    function init() {
        document.getElementById('agenda-home').innerHTML = agendaHTML;
        document.getElementById('agenda-jobs').innerHTML = agendaHTML;
        document.getElementById('full-job-list').innerHTML = jobsList.map(j => `<div class="job-list-item" onclick="openJobDetail(${j.id})"><div class="job-icon ${j.color}">J${j.id}</div><div><div style="font-size:12px; font-weight:800;">${j.name}</div><div style="font-size:10px; color:#7f8c8d;">${j.addr}</div></div><i class="fa-solid fa-chevron-right" style="margin-left:auto; color:#d1d8e0;"></i></div>`).join('');
        setInterval(() => { const now = new Date(); document.getElementById('liveClock').innerText = now.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' }).toUpperCase().replace(',', ' •'); }, 1000);
        updateUI();
    }
    function openMap(addr) { window.open(`https://maps.google.com/?q=${encodeURIComponent(addr)}`, '_blank'); }
    init();

    function openEditModal() {
    const dayNames = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"];
    const container = document.getElementById('modal-inputs');
    
    // Generates 7 inputs, converting your milliseconds (weekData) into decimal hours
    container.innerHTML = dayNames.map((day, i) => `
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
            <label style="font-size: 12px; font-weight: 700; color: #7f8c8d;">${day}</label>
            <input type="number" step="0.1" id="edit-day-${i}" 
                   style="width: 60px; padding: 8px; border: 1px solid #ddd; border-radius: 8px; text-align: center; font-weight: 800;" 
                   value="${(weekData[i] / 3600000).toFixed(1)}">
        </div>
    `).join('');
    
    document.getElementById('editModal').style.display = 'flex';
}

function closeEditModal() {
    document.getElementById('editModal').style.display = 'none';
}

function saveEditedHours() {
    for (let i = 0; i < 7; i++) {
        const val = parseFloat(document.getElementById(`edit-day-${i}`).value) || 0;
        // Converts back to milliseconds for your internal calculations
        weekData[i] = val * 3600000;
    }
    
    localStorage.setItem('cntrl_week_times_7day', JSON.stringify(weekData));
    
    // Runs your existing UI update function to refresh the bars and totals
    if (typeof updateUI === "function") updateUI();
    
    closeEditModal();
}



</script>
