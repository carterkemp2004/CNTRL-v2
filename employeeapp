<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CNTRL Dashboard</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap');

        :root {
            --primary-blue: #007bff;
            --success-green: #28a745;
            --emergency-red: #dc3545;
            --lunch-orange: #fd9644;
            --bg-light: #f8f9fa;
            --nav-bg: rgba(255, 255, 255, 0.9);
            --nav-btn-inactive: rgba(225, 232, 237, 0.6);
            --nav-btn-active: rgba(206, 214, 224, 1);
            --nav-icon-inactive: #a4b0be;
            --font-main: 'Inter', sans-serif;
            
            --site-1: #0984e3; --site-2: #6c5ce7; --site-3: #00b894;
            --site-4: #fdcb6e; --site-5: #e17055; --site-6: #fab1a0;
            --site-7: #fd79a8; --site-8: #a29bfe; --site-9: #00cec9;
            --site-10: #2d3436; --site-11: #e84393;
        }

        body { font-family: var(--font-main); background-color: #d1d8e0; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; color: #2d3436; }

        .phone-screen {
            width: 360px; height: 740px; background-color: var(--bg-light);
            border: 12px solid #1a1a1a; border-radius: 44px; box-shadow: 0 30px 60px rgba(0, 0, 0, 0.3);
            display: flex; flex-direction: column; overflow: hidden; position: relative;
        }

        header { padding: 25px 15px 5px; text-align: center; }
        .logo { font-size: 26px; font-weight: 800; color: var(--primary-blue); margin: 0; letter-spacing: -1.5px; }
        #liveClock { font-size: 10px; color: #a4b0be; text-transform: uppercase; letter-spacing: 1.5px; margin-top: 2px; font-weight: 700; }

        .content { padding: 0 16px 85px; flex: 1; overflow-y: auto; }
        .card { background: white; border-radius: 18px; padding: 15px; margin-bottom: 12px; box-shadow: 0 6px 15px rgba(0,0,0,0.03); }
        h2 { font-size: 10px; margin: 0 0 10px; color: #7f8c8d; text-transform: uppercase; letter-spacing: 1px; font-weight: 700; }
        .row { display: flex; justify-content: space-between; align-items: center; }

        .btn-map { background: white; color: var(--primary-blue); border: 1.5px solid var(--primary-blue); border-radius: 10px; padding: 4px 10px; font-size: 9px; font-weight: 800; cursor: pointer; }

        .schedule-container { height: 185px; overflow: hidden; border: 1px solid #f1f2f6; border-radius: 12px; padding: 5px 2px; }
        .timeline-grid { display: grid; grid-template-columns: 28px repeat(7, 1fr); gap: 1px; }
        .time-label { font-size: 6px; font-weight: 800; color: #b2bec3; height: 20px; display: flex; align-items: center; justify-content: flex-end; padding-right: 3px; border-bottom: 1px solid #f1f2f6; }
        .day-column { display: grid; grid-template-rows: repeat(18, 10px); border-left: 1px solid #f1f2f6; }
        .slot { border-bottom: 1px dotted #f1f2f6; height: 9px; position: relative; }
        .job-block { position: absolute; width: 90%; left: 5%; border-radius: 2px; color: white; font-size: 4px; font-weight: 800; display: flex; align-items: center; justify-content: center; z-index: 2; text-align: center; }
        
        .site-1 { background: var(--site-1); } .site-2 { background: var(--site-2); } .site-3 { background: var(--site-3); }
        .site-4 { background: var(--site-4); } .site-5 { background: var(--site-5); } .site-6 { background: var(--site-6); }
        .site-7 { background: var(--site-7); } .site-8 { background: var(--site-8); } .site-9 { background: var(--site-9); }
        .site-10 { background: var(--site-10); } .site-11 { background: var(--site-11); }
        .lunch-block { background: var(--lunch-orange); z-index: 1; opacity: 0.7; }

        .graph-container { display: grid; grid-template-rows: auto 1fr auto; gap: 4px 4px; height: 110px; align-items: end; }
        .bar-total { font-size: 8px; font-weight: 800; color: #2d3436; text-align: center; }
        .bar { width: 100%; border-radius: 3px 3px 0 0; transition: height 0.3s ease; }
        .graph-label { text-align: center; font-size: 8px; font-weight: 800; color: #b2bec3; padding-top: 8px; border-top: 2px solid #f1f2f6; white-space: nowrap; }

        .line-graph-svg { width: 100%; height: 130px; overflow: visible; }
        .line-dot { fill: var(--success-green); }
        .line-path { fill: none; stroke: var(--success-green); stroke-width: 3; stroke-linecap: round; stroke-linejoin: round; }
        .line-val { font-size: 11px; font-weight: 800; fill: #2d3436; text-anchor: middle; }

        .progress-container { position: relative; width: 80px; height: 80px; }
        .inner-stat-box { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; width: 100%; }
        .inner-stat-value { display: block; font-size: 11px; font-weight: 800; color: var(--success-green); line-height: 1; }
        .inner-stat-label { display: block; font-size: 7px; font-weight: 800; color: #a4b0be; text-transform: uppercase; margin-top: 2px; }

        .job-list-item { display: flex; align-items: center; padding: 12px; background: #fff; border-radius: 12px; margin-bottom: 8px; border: 1px solid #f1f2f6; cursor: pointer; }
        .job-icon { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; margin-right: 12px; color: white; font-size: 11px; font-weight: 800; }
        .btn-back { background: none; border: none; color: var(--primary-blue); font-weight: 800; font-size: 11px; cursor: pointer; padding: 0; margin-bottom: 12px; display: flex; align-items: center; gap: 5px; }
        .checklist-item { display: flex; align-items: center; gap: 10px; padding: 8px 0; border-bottom: 1px solid #f8f9fa; font-size: 12px; font-weight: 600; }
        .checklist-item input { accent-color: var(--success-green); width: 16px; height: 16px; }
        .note-box { background: #fff9e6; border-left: 3px solid #f1c40f; padding: 10px; font-size: 11px; color: #5a6263; border-radius: 4px; line-height: 1.4; }

        .pay-summary-big { font-size: 32px; font-weight: 800; color: var(--success-green); letter-spacing: -1px; margin: 2px 0; }
        .rate-badge { display: inline-block; background: #f1f2f6; color: #7f8c8d; font-size: 9px; font-weight: 800; padding: 4px 10px; border-radius: 20px; margin-bottom: 8px; }
        .btn-dispute { background: #fff0f0; color: var(--emergency-red); border: none; padding: 6px 12px; border-radius: 8px; font-size: 10px; font-weight: 800; cursor: pointer; width: 100%; margin-top: 10px; }

        nav { position: absolute; bottom: 12px; left: 50%; transform: translateX(-50%); width: 85%; display: flex; justify-content: space-evenly; padding: 8px 0; background-color: var(--nav-bg); backdrop-filter: blur(15px); border-radius: 22px; border: 1px solid rgba(255, 255, 255, 0.4); z-index: 10; }
        .nav-btn { background-color: var(--nav-btn-inactive); border: none; border-radius: 12px; width: 46px; height: 46px; display: flex; align-items: center; justify-content: center; cursor: pointer; }
        .nav-btn i { font-size: 16px; color: var(--nav-icon-inactive); }
        .nav-btn.active { background-color: var(--nav-btn-active); }
        .nav-btn.active i { color: var(--primary-blue); }

        #mainToggleBtn { width: 130px; height: 50px; border-radius: 12px; border: none; font-weight: 800; color: white; background: linear-gradient(135deg, #2ecc71, #27ae60); cursor: pointer; }

        .job-entry { border-bottom: 1px solid #f1f2f6; padding: 8px 0; }
        .job-entry:last-child { border-bottom: none; }
        .job-tag { font-size: 9px; font-weight: 800; color: white; padding: 2px 6px; border-radius: 4px; text-transform: uppercase; display: inline-block; margin-bottom: 4px; }
    </style>
</head>
