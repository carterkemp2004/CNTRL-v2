<script>
    const circ = 276.46;
    let weekData = JSON.parse(localStorage.getItem('cntrl_week_times_7day')) || [0, 0, 0, 0, 0, 0, 0];
    let isClockedIn = false;
    let startTime, elapsedTime = 0, timerInterval;
    const HOURLY_RATE = 20.00;

    function formatHM(ms) {
        const totalMin = Math.floor(ms / 60000);
        const h = Math.floor(totalMin / 60);
        const m = totalMin % 60;
        return `${h}H ${m.toString().padStart(2, '0')}M`;
    }

    function getMondayLabel(weeksAgo) {
        let d = new Date();
        let day = d.getDay(), diff = d.getDate() - day + (day == 0 ? -6 : 1);
        let monday = new Date(d.setDate(diff));
        monday.setDate(monday.getDate() - (weeksAgo * 7));
        return (monday.getMonth() + 1).toString().padStart(2, '0') + '/' + monday.getDate().toString().padStart(2, '0');
    }

    function calculatePayFromHrs(hrs) {
        const reg = Math.min(hrs, 40);
        const ot = Math.max(0, hrs - 40);
        return (reg * HOURLY_RATE) + (ot * HOURLY_RATE * 1.5);
    }

